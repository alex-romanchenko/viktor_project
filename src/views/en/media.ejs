<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Media — Viktor Romanchenko</title>
  <meta name="description" content="Videos, performances and stories." />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/style.css" />
  <link rel="stylesheet" href="/assets/pages.css" />
</head>

<body>
<header class="site-header" id="top">
  <div class="container header-inner">
    <a class="brand" href="/en" aria-label="Home">
      <span class="brand-logo">
        <img src="/images/logo.png" alt="Viktor Romanchenko logo" />
      </span>
      <span class="brand-name">Viktor Romanchenko</span>
    </a>

    <button class="burger" id="burger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="nav" id="nav" aria-label="Main menu">
      <a href="/en/news">News</a>
      <a href="/en/bio">Biography</a>
      <a href="/en/music">Music</a>
      <a class="is-active" href="/en/media">Media</a>
      <a href="/en/tour">Tour</a>
      <a href="/en/contacts">Contacts</a>
    </nav>

    <div class="lang">
      <a class="lang-link" href="/ua/media">UA</a>
      <span class="lang-sep">|</span>
      <a class="lang-link is-active" href="/en/media">EN</a>
    </div>
  </div>
</header>

<section class="section section-soft">
  <div class="container">
    <div class="section-head">
      <div>
        <h1>Media</h1>
        <p class="muted">Videos, live performances and stories</p>
      </div>
      <a class="text-link" href="/en">← Back to home</a>
    </div>

    <div class="tabs" role="tablist" aria-label="Media tabs">
      <button class="tab is-active" data-category="all" role="tab">All</button>
      <button class="tab" data-category="clips" role="tab">Clips</button>
      <button class="tab" data-category="x-factor" role="tab">X-Factor</button>
      <button class="tab" data-category="rock" role="tab">Rock Symphony</button>
      <button class="tab" data-category="stories" role="tab">Stories</button>
    </div>

    <% if (!mediaList || mediaList.length === 0) { %>
      <div class="empty-state">No videos yet.</div>
    <% } %>

    <% if (mediaList && mediaList.length > 0) { %>
      <div class="media-grid">
        <% mediaList.forEach(function(item) { %>
          <% const coverUrl = item.cover_image ? '/uploads/media/' + item.cover_image : ''; %>

          <article
            class="media-card"
            data-category="<%= item.category || 'clips' %>"
          >
            <% if (item.embedUrl) { %>
              <div class="media-video">
                <iframe
                  src="<%= item.embedUrl %>"
                  title="<%= item.title %>"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
            <% } else if (coverUrl) { %>
              <div
                class="media-thumb"
                style="background-image:url('<%= coverUrl %>');"
              ></div>
            <% } %>

            <div class="media-body">
              <h3 class="media-title"><%= item.title %></h3>
              <p class="muted"><%= item.description || 'Video' %></p>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>

    <footer class="footer">
      <div class="container footer-inner">
        <span>© <span id="year"></span> Viktor Romanchenko</span>
      </div>
    </footer>
  </div>
</section>

<button class="scroll-top" id="scrollTopBtn" type="button" aria-label="Back to top">
  ↑
</button>

<script src="/assets/script.js"></script>
<script src="/assets/media.js" defer></script>
</body>
</html>
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Music — Viktor Romanchenko</title>
  <meta name="description" content="Listen to tracks directly on the website." />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/style.css" />
  <link rel="stylesheet" href="/assets/pages.css" />
</head>

<body>
  <header class="site-header" id="top">
    <div class="container header-inner">
      <a class="brand" href="/en" aria-label="Home">
        <span class="brand-logo">
          <img src="/images/logo.png" alt="Viktor Romanchenko logo" />
        </span>
        <span class="brand-name">Viktor Romanchenko</span>
      </a>

      <button class="burger" id="burger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav" id="nav" aria-label="Main menu">
        <a href="/en/news">News</a>
        <a href="/en/bio">Biography</a>
        <a href="/en/music">Music</a>
        <a href="/en/media">Media</a>
        <a href="/en/tour">Tour</a>
        <a href="/en/contacts">Contacts</a>
      </nav>

      <div class="lang">
        <a class="lang-link" href="/ua/music">UA</a>
        <span class="lang-sep">|</span>
        <a class="lang-link is-active" href="/en/music">EN</a>
      </div>
    </div>
  </header>

  <section class="section section-soft">
    <div class="container">
      <div class="section-head">
        <div>
          <h1>Music</h1>
        </div>
        <a class="text-link" href="/en">← Home</a>
      </div>

      <% if (latestTrack) { %>
        <% const latestCoverUrl = latestTrack.cover_image ? '/uploads/covers/' + latestTrack.cover_image : '/images/cover-1.jpg'; %>

        <section class="player panel" aria-label="Audio player">
          <div class="player-left">
            <div
              class="player-cover"
              id="playerCover"
              style="background-image: url('<%= latestCoverUrl %>');"
            ></div>
          </div>

          <div class="player-right">
            <div class="player-top">
              <div>
                <p class="kicker" id="playerBadge">Paused</p>
                <h2 class="player-title" id="playerTitle"><%= latestTrack.title %></h2>
                <p class="muted" id="playerMeta"><%= latestTrack.description || 'New release' %></p>
              </div>

              <div class="player-actions">
                <button class="btn btn-ghost btn-small" id="btnPrev" type="button" aria-label="Previous track">⏮</button>
                <button class="btn btn-primary" id="btnPlay" type="button" aria-label="Play / Pause">▶ Play</button>
                <button class="btn btn-ghost btn-small" id="btnNext" type="button" aria-label="Next track">⏭</button>
              </div>
            </div>

            <div class="player-seek">
              <span class="meta" id="timeCurrent">0:00</span>
              <input id="seek" class="seek" type="range" min="0" max="100" value="0" step="0.1" aria-label="Seek">
              <span class="meta" id="timeTotal">0:00</span>
            </div>

            <div class="player-bottom">
              <div class="join">
                <span class="meta join-title">Join in</span>

                <div class="join-links">
                  <a class="chip chip-light" href="https://www.facebook.com/vik.romanchenko" target="_blank" rel="noopener">Facebook</a>
                  <a class="chip chip-light" href="https://www.tiktok.com/@viktorromanchenko_fizruk?_r=1" target="_blank" rel="noopener">TikTok</a>
                  <a class="chip chip-light" href="https://www.instagram.com/_viktorromanchenko_/" target="_blank" rel="noopener">Instagram</a>
                  <a class="chip chip-light" href="https://www.youtube.com/@_Fizruk_" target="_blank" rel="noopener">YouTube</a>
                </div>

                <p class="muted join-note">Follow for new releases, videos, and tour dates.</p>
              </div>
            </div>

            <audio
              id="audio"
              preload="metadata"
              src="/uploads/music/<%= latestTrack.audio %>"
            ></audio>
          </div>
        </section>
      <% } else { %>
        <div class="empty-state">No tracks yet.</div>
      <% } %>

      <div class="section-head" style="margin-top:26px;">
        <h2>Tracks</h2>
      </div>

      <div class="tabs" role="tablist">
        <button class="tab is-active" data-genre="all" role="tab">All</button>
        <button class="tab" data-genre="own-songs" role="tab">Original songs</button>
        <button class="tab" data-genre="x-factor" role="tab">X-Factor</button>
        <button class="tab" data-genre="rock" role="tab">Rock Symphony</button>
      </div>

      <div class="music-grid">
        <% tracks.forEach(function(track) { %>
          <% const coverUrl = track.cover_image ? '/uploads/covers/' + track.cover_image : '/images/cover-1.jpg'; %>

          <article
            class="track-card"
            data-genre="<%= track.category || 'all' %>"
            data-title="<%= track.title %>"
            data-meta="<%= track.description || 'Track' %>"
            data-cover="<%= coverUrl %>"
            data-src="/uploads/music/<%= track.audio %>"
          >
            <div
              class="track-cover-lg"
              style="background-image: url('<%= coverUrl %>');"
            ></div>

            <h3 class="track-title-lg"><%= track.title %></h3>
            <p class="muted"><%= track.description || 'Track' %></p>

            <div class="row">
              <button class="btn btn-primary js-card-play" type="button">▶ Play</button>
            </div>
          </article>
        <% }) %>
      </div>

      <footer class="footer">
        <div class="container footer-inner">
          <span>© <span id="year"></span> Viktor Romanchenko</span>
        </div>
      </footer>
    </div>
  </section>

  <button class="scroll-top" id="scrollTopBtn" type="button" aria-label="Back to top">
    ↑
  </button>

  <script src="/assets/script.js"></script>
  <script src="/assets/music.js" defer></script>
</body>
</html>
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Contacts — Viktor Romanchenko</title>
  <meta name="description" content="Contacts for сотрудничества, concerts and media inquiries." />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="../assets/style.css" />
  <link rel="stylesheet" href="../assets/pages.css" />
</head>

<body>
<header class="site-header" id="top">
  <div class="container header-inner">
    <a class="brand" href="../en/" aria-label="Home">
      <span class="brand-logo">
        <img src="../images/logo.png" alt="Viktor Romanchenko logo" />
      </span>
      <span class="brand-name">Viktor Romanchenko</span>
    </a>

    <button class="burger" id="burger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="nav" id="nav" aria-label="Main menu">
      <a href="../en/news">News</a>
      <a href="../en/bio">Biography</a>
      <a href="../en/music">Music</a>
      <a href="../en/media">Media</a>
      <a href="../en/tour">Tour</a>
      <a class="is-active" href="contacts">Contacts</a>
    </nav>

    <div class="lang">
      <a class="lang-link" href="../ua/contacts">UA</a>
      <span class="lang-sep">|</span>
      <a class="lang-link is-active" href="../en/contacts">EN</a>
    </div>
  </div>
</header>

<section class="section section-soft">
  <div class="container">
    <div class="section-head">
      <div>
        <h1>Contacts</h1>
        <p class="muted">For collaborations, concerts, and media inquiries.</p>
      </div>
      <a class="text-link" href="../en/">← Back to home</a>
    </div>

    <!-- CONTACTS layout -->
    <div class="contacts-grid">
      <!-- LEFT -->
      <div class="panel">
        <h2 style="margin:0 0 10px;">Contacts</h2>
        <p class="muted" style="margin:0 0 16px;">For collaborations, concerts, and media inquiries.</p>

        <div class="contact-card">
          <p class="kicker">BOOKING</p>
          <a href="tel:<%= contacts.phone %>"><%= contacts.phone %></a>
        </div>

        <div class="contact-card" style="margin-top:12px;">
          <p class="kicker">EMAIL</p>
          <a href="mailto:<%= contacts.email %>"><%= contacts.email %></a>
        </div>

        <div class="contact-card" style="margin-top:12px;">
          <p class="kicker">SOCIAL MEDIA</p>
          <div class="chips">
            <a href="#" class="chip" target="_blank" rel="noopener">Instagram</a>
            <a href="#" class="chip" target="_blank" rel="noopener">YouTube</a>
            <a href="#" class="chip" target="_blank" rel="noopener">TikTok</a>
          </div>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="panel">
        <h2 style="margin:0 0 10px;">Send a message</h2>

        <form class="contact-form" action="#" method="post">
          <div class="form-grid">
            <label class="field">
              <span class="meta">Name</span>
              <input class="input" type="text" name="name" placeholder="Your name" autocomplete="name" />
            </label>

            <label class="field">
              <span class="meta">Email</span>
              <input class="input" type="email" name="email" placeholder="name@email.com" autocomplete="email" />
            </label>
          </div>

          <label class="field" style="margin-top:12px;">
            <span class="meta">Message</span>
            <textarea class="textarea" name="message" rows="6" placeholder="Write what you are interested in..."></textarea>
          </label>

          <div style="margin-top:12px; display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
            <button class="btn btn-primary" type="submit">Send</button>
            <span class="muted" style="font-size:13px;">
              *This form is currently a mockup. We will connect submission later (PHP/Telegram/Google Forms).
            </span>
          </div>
        </form>
      </div>
    </div>

    <footer class="footer">
      <div class="container footer-inner">
        <span>© <span id="year"></span> Viktor Romanchenko</span>
      </div>
    </footer>
  </div>
</section>

<button class="scroll-top" id="scrollTopBtn" type="button" aria-label="Up">
  ↑
</button>

<script src="../assets/script.js"></script>
</body>
</html>
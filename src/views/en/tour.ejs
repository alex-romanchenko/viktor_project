<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Tour — Viktor Romanchenko</title>
  <meta name="description" content="Concerts and events." />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/style.css" />
  <link rel="stylesheet" href="/assets/pages.css" />
</head>

<body>
<header class="site-header" id="top">
  <div class="container header-inner">
    <a class="brand" href="/en" aria-label="Home">
      <span class="brand-logo">
        <img src="/images/logo.png" alt="Viktor Romanchenko logo" />
      </span>
      <span class="brand-name">Viktor Romanchenko</span>
    </a>

    <button class="burger" id="burger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="nav" id="nav" aria-label="Main menu">
      <a href="/en/news">News</a>
      <a href="/en/bio">Biography</a>
      <a href="/en/music">Music</a>
      <a href="/en/media">Media</a>
      <a class="is-active" href="/en/tour">Tour</a>
      <a href="/en/contacts">Contacts</a>
    </nav>

    <div class="lang">
      <a class="lang-link" href="/ua/tour">UA</a>
      <span class="lang-sep">|</span>
      <a class="lang-link is-active" href="/en/tour">EN</a>
    </div>
  </div>
</header>

<section class="section section-soft">
  <div class="container">
    <div class="section-head">
      <div>
        <h1>Tour</h1>
      </div>
      <a class="text-link" href="/en">← Back to home</a>
    </div>

    <% if (!events || events.length === 0) { %>
      <div class="tour-empty panel">
        <h3 style="margin:0 0 6px;">No concerts announced yet</h3>
        <p class="muted" style="margin:0;">Follow social media for updates — new tour dates will appear here.</p>
      </div>
    <% } %>

    <% if (events && events.length > 0) { %>
      <div class="tour-list">

        <% events.forEach(function(event) { %>
          <%
            const eventDate = new Date(event.date);
            const day = eventDate.getDate().toString().padStart(2, '0');
            const month = eventDate.toLocaleString('en-GB', { month: 'short' });
            const year = eventDate.getFullYear();
          %>

          <article class="tour-card panel">
            <div class="tour-date">
              <span class="tour-day"><%= day %></span>
              <span class="tour-mon"><%= month %></span>
              <span class="tour-yr"><%= year %></span>
            </div>

            <div class="tour-main">
              <h3 class="tour-title"><%= event.title %></h3>

              <p class="muted tour-meta">
                <% if (event.city) { %>
                  <span class="chip chip-light"><%= event.city %></span>
                <% } %>

                <% if (event.time) { %>
                  <% if (event.city) { %><span class="dot">•</span><% } %>
                  <span><%= event.time %></span>
                <% } %>

                <% if (event.place) { %>
                  <% if (event.city || event.time) { %><span class="dot">•</span><% } %>
                  <span><%= event.place %></span>
                <% } %>
              </p>

              <% if (event.description) { %>
                <p class="tour-sub muted"><%= event.description %></p>
              <% } %>
            </div>

            <div class="tour-actions">
              <% if (event.ticket_link) { %>
                <a
                  class="btn btn-primary"
                  href="<%= event.ticket_link %>"
                  target="_blank"
                  rel="noopener"
                >
                  Tickets
                </a>
              <% } %>
            </div>
          </article>
        <% }) %>

      </div>
    <% } %>

    <footer class="footer">
      <div class="container footer-inner">
        <span>© <span id="year"></span> Viktor Romanchenko</span>
      </div>
    </footer>
  </div>
</section>

<button class="scroll-top" id="scrollTopBtn" type="button" aria-label="Back to top">
  ↑
</button>

<script src="/assets/script.js"></script>
</body>
</html>
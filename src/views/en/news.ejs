<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>News — Viktor Romanchenko</title>
  <meta name="description" content="Latest news, releases, shows and updates." />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/style.css" />
  <link rel="stylesheet" href="/assets/pages.css" />
</head>

<body>
  <header class="site-header" id="top">
    <div class="container header-inner">
      <a class="brand" href="/en" aria-label="Home">
        <span class="brand-logo">
          <img src="/images/logo.png" alt="Viktor Romanchenko logo" />
        </span>
        <span class="brand-name">Viktor Romanchenko</span>
      </a>

      <button class="burger" id="burger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav" id="nav" aria-label="Main menu">
        <a href="/en/news">News</a>
        <a href="/en/bio">Biography</a>
        <a href="/en/music">Music</a>
        <a href="/en/media">Media</a>
        <a href="/en/tour">Tour</a>
        <a href="/en/contacts">Contacts</a>
      </nav>

      <div class="lang">
        <a class="lang-link" href="/ua/news">UA</a>
        <span class="lang-sep">|</span>
        <a class="lang-link is-active" href="/en/news">EN</a>
      </div>
    </div>
  </header>

  <section class="section section-soft">
    <div class="container">
      <div class="section-head">
        <h2>News</h2>
        <a class="text-link" href="/en">← Home</a>
      </div>

      <% if (!news || news.length === 0) { %>
        <div class="empty-state">No news yet.</div>
      <% } %>

      <% if (news && news.length > 0) { %>
        <div class="news-list">
          <% news.forEach(function(item) { %>
            <% const imageUrl = item.image ? item.image : '/images/news-1.jpg'; %>

            <article class="news-item-card">
              <a class="news-item-cover" href="/en/news/<%= item.slug %>">
                <img src="<%= imageUrl %>" alt="<%= item.title %>">
              </a>

              <div class="news-item-body">
                <% if (item.created_at) { %>
                  <div class="news-item-meta">
                    <%= new Date(item.created_at).toLocaleDateString('en-GB', {
                      day: '2-digit',
                      month: 'long',
                      year: 'numeric'
                    }) %>
                  </div>
                <% } %>

                <h3 class="news-item-title">
                  <a href="/en/news/<%= item.slug %>"><%= item.title %></a>
                </h3>

                <p class="news-item-excerpt"><%= item.excerpt || 'News update' %></p>

                <a class="news-item-btn" href="/en/news/<%= item.slug %>">Read more</a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>

      <footer class="footer">
        <div class="container footer-inner">
          <span>© <span id="year"></span> Viktor Romanchenko</span>
        </div>
      </footer>
    </div>
  </section>

  <button class="scroll-top" id="scrollTopBtn" type="button" aria-label="Back to top">
    ↑
  </button>

  <script src="/assets/script.js"></script>
</body>
</html>
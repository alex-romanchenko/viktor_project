<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= article ? article.title : 'News' %> — Viktor Romanchenko</title>
  <meta name="description" content="<%= article && article.excerpt ? article.excerpt : 'News and updates from Viktor Romanchenko.' %>" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/style.css" />
  <link rel="stylesheet" href="/assets/pages.css" />
</head>

<body>
  <header class="site-header" id="top">
    <div class="container header-inner">
      <a class="brand" href="/en" aria-label="Home">
        <span class="brand-logo">
          <img src="/images/logo.png" alt="Viktor Romanchenko logo" />
        </span>
        <span class="brand-name">Viktor Romanchenko</span>
      </a>

      <button class="burger" id="burger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav" id="nav" aria-label="Main menu">
        <a href="/en/news">News</a>
        <a href="/en/bio">Biography</a>
        <a href="/en/music">Music</a>
        <a href="/en/media">Media</a>
        <a href="/en/tour">Tour</a>
        <a href="/en/contacts">Contacts</a>
      </nav>

      <div class="lang">
        <a class="lang-link" href="/ua/news/">UA</a>
        <span class="lang-sep">|</span>
        <a class="lang-link is-active" href="/en/news/<%= article.slug %>">EN</a>
      </div>
    </div>
  </header>

  <section class="section section-soft">
    <div class="container">
      <div class="post">
        <a class="text-link" href="/en/news">← Back to news</a>

        <h1 style="margin-top:12px;"><%= article.title %></h1>

        <% if (article.created_at) { %>
          <p class="meta">
            <%= new Date(article.created_at).toLocaleDateString('en-GB', {
              day: '2-digit',
              month: 'long',
              year: 'numeric'
            }) %>
          </p>
        <% } %>

        <% const imageUrl = article.image ? article.image : '/images/news-1.jpg'; %>
        <div class="post-hero" style="background-image:url('<%= imageUrl %>');"></div>

        <% if (article.excerpt) { %>
          <p class="muted"><%= article.excerpt %></p>
        <% } %>

        <div class="post-content">
          <p><%= article.content %></p>
        </div>

        <div class="row">
          <a class="btn btn-primary" href="/en/music">Go to Music</a>
          <a class="btn btn-ghost" href="/en/media">Media</a>
        </div>

        <div class="post-nav">
          <a class="btn btn-small btn-ghost" href="/en/news">← All news</a>
        </div>
      </div>

      <footer class="footer">
        <div class="container footer-inner">
          <span>© <span id="year"></span> Viktor Romanchenko</span>
        </div>
      </footer>
    </div>
  </section>

  <button class="scroll-top" id="scrollTopBtn" type="button" aria-label="Back to top">
    ↑
  </button>

  <script src="/assets/script.js"></script>
</body>
</html>
<!doctype html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= article.title %> — Віктор Романченко</title>
  <meta name="description" content="<%= article.excerpt || article.title %>" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/assets/style.css" />
  <link rel="stylesheet" href="/assets/pages.css" />
</head>
<body>
  <header class="site-header" id="top">
    <div class="container header-inner">
      <a class="brand" href="/ua" aria-label="На головну">
        <span class="brand-logo">
          <img src="/images/logo.png" alt="Viktor Romanchenko logo" />
        </span>
        <span class="brand-name">Віктор Романченко</span>
      </a>

      <button class="burger" id="burger" aria-label="Відкрити меню" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav" id="nav" aria-label="Головне меню">
        <a class="is-active" href="/ua/news">Новини</a>
        <a href="/ua/bio">Біографія</a>
        <a href="/ua/music">Музика</a>
        <a href="/ua/media">Медіа</a>
        <a href="/ua/tour">Афіша</a>
        <a href="/ua/contacts">Контакти</a>
      </nav>

      <div class="lang">
        <a class="lang-link is-active" href="/ua/news/<%= article.slug %>">UA</a>
        <span class="lang-sep">|</span>
        <a class="lang-link" href="/en/news">EN</a>
      </div>
    </div>
  </header>

  <section class="section section-soft">
    <div class="container article-wrap">
      <a class="back-link article-back" href="/ua/news">← Назад до новин</a>

      <article class="article-card">
        <div class="article-cover">
          <img
            src="<%= article.image || '/images/news-placeholder.jpg' %>"
            alt="<%= article.title %>"
          />
        </div>

        <div class="article-content">
          <div class="article-meta">
            <span>
              <%= new Date(article.created_at).toLocaleDateString('uk-UA', {
                day: '2-digit',
                month: 'long',
                year: 'numeric'
              }) %>
            </span>
          </div>

          <h1><%= article.title %></h1>

          <% if (article.excerpt) { %>
            <p class="article-lead"><%= article.excerpt %></p>
          <% } %>

          <div class="article-text">
            <%- (article.content || '').replace(/\n/g, '<br>') %>
          </div>
        </div>
      </article>
    </div>
  </section>
    <button class="scroll-top" id="scrollTopBtn" type="button" aria-label="Вгору">
      ↑
    </button>
  <script src="/assets/script.js"></script>
</body>
</html>
<!doctype html>
<html lang="uk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Контакти — Віктор Романченко</title>
  <meta name="description" content="Контакти для співпраці, концертів та медіа-запитів." />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="../assets/style.css" />
  <link rel="stylesheet" href="../assets/pages.css" />
</head>

<body>
<header class="site-header" id="top">
  <div class="container header-inner">
    <a class="brand" href="../ua/" aria-label="На головну">
    <span class="brand-logo">
        <img src="../images/logo.png" alt="Viktor Romanchenko logo" />
      </span>
      <span class="brand-name">Віктор Романченко</span>
    </a>

    <button class="burger" id="burger" aria-label="Відкрити меню" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="nav" id="nav" aria-label="Головне меню">
        <a href="../ua/news">Новини</a>
        <a href="../ua/bio">Біографія</a>
        <a href="../ua/music">Музика</a>
        <a href="../ua/media">Медіа</a>
        <a class="is-active" href="../ua/tour">Афіша</a>
        <a class="is-active" href="contacts">Контакти</a>
    </nav>
      <div class="lang">
        <a class="lang-link is-active" href="../ua/contacts">UA</a>
        <span class="lang-sep">|</span>
        <a class="lang-link" href="../en/contacts">EN</a>
      </div>
  </div>
</header>

<section class="section section-soft">
  <div class="container">
    <div class="section-head">
      <div>
        <h1>Контакти</h1>
        <p class="muted">Для співпраці, концертів та медіа-запитів.</p>
      </div>
      <a class="text-link" href="../ua/">← На головну</a>
    </div>

    <!-- CONTACTS layout (як на головній) -->
    <div class="contacts-grid">
      <!-- LEFT -->
      <div class="panel">
        <h2 style="margin:0 0 10px;">Контакти</h2>
        <p class="muted" style="margin:0 0 16px;">Для співпраці, концертів та медіа-запитів.</p>

        <div class="contact-card">
          <p class="kicker">Телефон</p>
          <a href="tel:<%= contacts.phone %>"><%= contacts.phone %></a>
        </div>

        <div class="contact-card" style="margin-top:12px;">
          <p class="kicker">EMAIL</p>
          <a href="mailto:<%= contacts.email %>"><%= contacts.email %></a>
        </div>

        <div class="contact-card" style="margin-top:12px;">
          <p class="kicker">СОЦМЕРЕЖІ</p>
          <div class="chips">
            <a href="#" class="chip" target="_blank" rel="noopener">Instagram</a>
            <a href="#" class="chip" target="_blank" rel="noopener">YouTube</a>
            <a href="#" class="chip" target="_blank" rel="noopener">TikTok</a>
          </div>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="panel">
        <h2 style="margin:0 0 10px;">Написати повідомлення</h2>

        <form class="contact-form" action="#" method="post">
          <div class="form-grid">
            <label class="field">
              <span class="meta">Ім’я</span>
              <input class="input" type="text" name="name" placeholder="Ваше ім’я" autocomplete="name" />
            </label>

            <label class="field">
              <span class="meta">Email</span>
              <input class="input" type="email" name="email" placeholder="name@email.com" autocomplete="email" />
            </label>
          </div>

          <label class="field" style="margin-top:12px;">
            <span class="meta">Повідомлення</span>
            <textarea class="textarea" name="message" rows="6" placeholder="Напишіть, що вас цікавить..." ></textarea>
          </label>

          <div style="margin-top:12px; display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
            <button class="btn btn-primary" type="submit">Надіслати</button>
            <span class="muted" style="font-size:13px;">
              *Форма зараз “макет”. Пізніше підключимо відправку (PHP/Telegram/Google Forms).
            </span>
          </div>
        </form>
      </div>
    </div>

    <footer class="footer">
      <div class="container footer-inner">
        <span>© <span id="year"></span> Віктор Романченко</span>
      </div>
    </footer>
  </div>
</section>
    <button class="scroll-top" id="scrollTopBtn" type="button" aria-label="Вгору">
      ↑
    </button>
<script src="../assets/script.js"></script>
</body>
</html>

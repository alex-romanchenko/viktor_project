<!doctype html>
<html lang="uk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Віктор Романченко — офіційний сайт</title>
  <meta name="description" content="Офіційний сайт співака Віктора Романченка: новини, музика, медіа, афіша, контакти." />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/style.css" />
  <link rel="stylesheet" href="/assets/pages.css" />
</head>

<body>
  <header class="site-header" id="top">
    <div class="container header-inner">
      <a class="brand" href="/ua" aria-label="На головну">
        <span class="brand-logo">
          <img src="/images/logo.png" alt="Viktor Romanchenko logo" />
        </span>
        <span class="brand-name">Віктор Романченко</span>
      </a>

      <button class="burger" id="burger" aria-label="Відкрити меню" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav" id="nav" aria-label="Головне меню">
        <a href="/ua/news">Новини</a>
        <a href="/ua/bio">Біографія</a>
        <a href="/ua/music">Музика</a>
        <a href="/ua/media">Медіа</a>
        <a href="/ua/tour">Афіша</a>
        <a href="/ua/contacts">Контакти</a>
      </nav>

      <div class="lang">
        <a class="lang-link is-active" href="/ua/">UA</a>
        <span class="lang-sep">|</span>
        <a class="lang-link" href="/en/">EN</a>
      </div>
    </div>
  </header>

  <section class="hero">
    <div class="hero-bg" style="background-image:url('/images/hero.jpg');"></div>
    <div class="hero-overlay"></div>

    <div class="container hero-inner">
      <div class="hero-left">
        <div class="hero-links">
          <a href="https://www.youtube.com/@_Fizruk_" aria-label="YouTube" class="chip" target="_blank" rel="noopener">YouTube</a>
          <a href="https://www.instagram.com/_viktorromanchenko_/" aria-label="Instagram" class="chip" target="_blank" rel="noopener">Instagram</a>
          <a href="https://www.tiktok.com/@viktorromanchenko_fizruk?_r=1" aria-label="TikTok" class="chip" target="_blank" rel="noopener">TikTok</a>
          <a href="https://open.spotify.com/artist/7yMrPREhiFUIEXvvA463yT" aria-label="Spotify" class="chip" target="_blank" rel="noopener">Spotify</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="news">
    <div class="container">
      <div class="section-head">
        <h2>Останні новини</h2>
        <a class="text-link" href="/ua/news">Усі новини →</a>
      </div>

      <% if (!latestNews || latestNews.length === 0) { %>
        <div class="empty-state">Новини поки що не додані.</div>
      <% } %>

      <% if (latestNews && latestNews.length > 0) { %>
        <div class="grid grid-3">
          <% latestNews.forEach(function(item) { %>
            <% const imageUrl = item.image ? item.image : '/images/news-1.jpg'; %>

            <article class="card">
              <div class="card-media" style="background-image:url('<%= imageUrl %>');"></div>
              <div class="card-body">
                <% if (item.created_at) { %>
                  <p class="meta"><%= new Date(item.created_at).toLocaleDateString('uk-UA') %></p>
                <% } %>
                <h3><%= item.title %></h3>
                <p class="muted"><%= item.excerpt || 'Новина сайту' %></p>
                <a class="btn btn-small btn-ghost" href="/ua/news/<%= item.slug %>">Читати далі</a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section section-dark" id="bio">
    <div class="container bio">
      <div class="bio-photo" style="background-image:url('/images/bio.jpg');"></div>

      <div class="bio-text">
        <p class="kicker">Про Віктора</p>
        <h2>Біографія</h2>
        <p class="muted">
          Віктор Романченко — співак і виконавець авторських пісень. Тут коротко: стиль, характер, сцена,
          ключові події.
        </p>

        <ul class="bullets">
          <li>Фіналіст / учасник музичних проєктів</li>
          <li>Живі виступи та концерти</li>
          <li>Прем’єри треків і кліпів</li>
        </ul>

        <a class="btn btn-primary" href="/ua/bio">Читати повну біографію</a>
      </div>
    </div>
  </section>

  <section class="section" id="music">
    <div class="container">
      <div class="section-head">
        <h2>Музика</h2>
        <a class="text-link" href="/ua/music">Уся музика →</a>
      </div>

      <% if (!latestTracks || latestTracks.length === 0) { %>
        <div class="empty-state">Треки поки що не додані.</div>
      <% } %>

      <% if (latestTracks && latestTracks.length > 0) { %>
        <div class="grid grid-2">
          <div class="panel">
            <h3>Останні треки</h3>

            <% latestTracks.forEach(function(track) { %>
              <% const coverUrl = track.cover_image ? '/uploads/covers/' + track.cover_image : '/images/cover-1.jpg'; %>

              <div class="track">
                <div class="track-left">
                  <div class="track-cover" style="background-image:url('<%= coverUrl %>');"></div>
                  <div>
                    <div class="track-title"><%= track.title %></div>
                    <div class="muted"><%= track.description || 'Трек' %></div>
                  </div>
                </div>
                <div class="track-actions">
                  <a class="btn btn-small btn-ghost" href="/ua/music">Слухати</a>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="panel">
            <h3>Плеєр</h3>

            <% if (latestTracks[0]) { %>
              <div class="embed">
                <audio controls style="width:100%;">
                  <source src="/uploads/music/<%= latestTracks[0].audio %>" type="audio/mpeg">
                </audio>
              </div>
            <% } %>

            <div class="row">
              <a class="btn btn-small btn-primary" href="https://open.spotify.com/artist/7yMrPREhiFUIEXvvA463yT" target="_blank" rel="noopener">Spotify</a>
              <a class="btn btn-small btn-ghost" href="/ua/music">Уся музика</a>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section section-soft" id="media">
    <div class="container">
      <div class="section-head">
        <h2>Медіа</h2>
        <a class="text-link" href="/ua/media">Усе медіа →</a>
      </div>

      <% if (!latestMedia || latestMedia.length === 0) { %>
        <div class="empty-state">Медіа поки що не додано.</div>
      <% } %>

      <% if (latestMedia && latestMedia.length > 0) { %>
        <div class="grid grid-3">
          <% latestMedia.forEach(function(item) { %>
            <article class="media-card" style="cursor:default;">
              <% if (item.embedUrl) { %>
                <div class="media-video">
                  <iframe
                    src="<%= item.embedUrl %>"
                    title="<%= item.title %>"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    referrerpolicy="strict-origin-when-cross-origin"
                    allowfullscreen
                  ></iframe>
                </div>
              <% } else { %>
                <% const mediaCover = item.cover_image ? '/uploads/media/' + item.cover_image : '/images/video-1.jpg'; %>
                <div class="media-thumb" style="background-image:url('<%= mediaCover %>');"></div>
              <% } %>

              <div class="media-body">
                <div class="media-title"><%= item.title %></div>
                <div class="muted"><%= item.description || 'Відео' %></div>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section" id="tour">
    <div class="container">
      <div class="section-head">
        <h2>Афіша</h2>
        <a class="text-link" href="/ua/tour">Уся афіша →</a>
      </div>

      <% if (!latestEvents || latestEvents.length === 0) { %>
        <div class="empty-state">Події поки що не додані.</div>
      <% } %>

      <% if (latestEvents && latestEvents.length > 0) { %>
        <div class="panel">
          <% latestEvents.forEach(function(event) { %>
            <% const eventDate = new Date(event.date); %>
            <div class="event">
              <div class="event-date">
                <div class="day"><%= eventDate.getDate().toString().padStart(2, '0') %></div>
                <div class="mon"><%= eventDate.toLocaleString('uk-UA', { month: 'short' }).toUpperCase() %></div>
              </div>
              <div class="event-info">
                <div class="event-title"><%= event.title %></div>
                <div class="muted">
                  <%= event.time || '' %>
                  <% if (event.city) { %> • <%= event.city %><% } %>
                  <% if (event.place) { %> • <%= event.place %><% } %>
                </div>
              </div>
              <div class="event-actions">
                <% if (event.ticket_link) { %>
                  <a class="btn btn-small btn-primary" href="<%= event.ticket_link %>" target="_blank" rel="noopener">Квитки</a>
                <% } else { %>
                  <a class="btn btn-small btn-ghost" href="/ua/tour">Деталі</a>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section section-dark" id="contacts">
    <div class="container contacts">
      <div>
        <h2>Контакти</h2>
        <p class="muted">Для співпраці, концертів та медіа-запитів.</p>

        <div class="contact-list">
          <div class="contact-item">
            <span class="label">Booking</span>
            <a href="tel:<%= contacts.phone %>"><%= contacts.phone %></a>
          </div>

          <div class="contact-item">
            <span class="label">Email</span>
            <a href="mailto:<%= contacts.email %>"><%= contacts.email %></a>
          </div>

          <div class="contact-item">
            <span class="label">Соцмережі</span>
            <div class="row">
              <a class="chip" href="https://www.instagram.com/_viktorromanchenko_/" target="_blank" rel="noopener">Instagram</a>
              <a class="chip" href="https://www.youtube.com/@_Fizruk_" target="_blank" rel="noopener">YouTube</a>
              <a class="chip" href="https://www.tiktok.com/@viktorromanchenko_fizruk?_r=1" target="_blank" rel="noopener">TikTok</a>
              <a class="chip" href="https://open.spotify.com/artist/7yMrPREhiFUIEXvvA463yT" target="_blank" rel="noopener">Spotify</a>
            </div>
          </div>
        </div>
      </div>

      <form class="form" action="#" method="post">
        <h3>Написати повідомлення</h3>
        <div class="grid grid-2">
          <label>
            Ім’я
            <input type="text" name="name" placeholder="Ваше ім’я" required>
          </label>

          <label>
            Email
            <input type="email" name="email" placeholder="name@email.com" required>
          </label>
        </div>

        <label>
          Повідомлення
          <textarea name="message" rows="5" placeholder="Напишіть, що вас цікавить..." required></textarea>
        </label>

        <button class="btn btn-primary" type="submit">Надіслати</button>
        <p class="muted small">*Форма зараз “макет”. Пізніше підключимо відправку.</p>
      </form>
    </div>

    <footer class="footer">
      <div class="container footer-inner">
        <span>© <span id="year"></span> Віктор Романченко</span>
      </div>
    </footer>
  </section>
    <button class="scroll-top" id="scrollTopBtn" type="button" aria-label="Вгору">
      ↑
    </button>
  <script src="/assets/script.js"></script>
</body>
</html>
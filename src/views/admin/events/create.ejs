<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Додати подію</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/admin.css" />
</head>
<body class="admin-body">
  <div class="admin-shell">
    <div class="admin-topbar">
      <div>
        <div class="admin-brand">Admin <span>Panel</span></div>
        <div class="admin-user">Додавання події</div>
      </div>

      <form method="POST" action="/admin/logout">
        <button class="btn btn-secondary" type="submit">Вийти</button>
      </form>
    </div>

    <div class="admin-grid">
      <aside class="admin-sidebar">
        <nav class="admin-nav">
          <a href="/admin">Головна</a>
          <a href="/admin/news">Новини</a>
          <a href="/admin/music">Музика</a>
          <a href="/admin/media">Медіа</a>
          <a class="is-active" href="/admin/events">Афіша</a>
          <a href="/admin/contacts">Контакти</a>
          <a href="/ua" target="_blank">Відкрити сайт</a>
        </nav>
      </aside>

      <main class="admin-panel">
        <h1 class="admin-title">Додати подію</h1>
        <p class="admin-subtitle">Заповни дані для афіші.</p>

        <form class="admin-form" method="POST" action="/admin/events/create">
          <div class="admin-field">
            <label for="title">Назва події</label>
            <input id="title" type="text" name="title" required />
          </div>

          <div class="admin-field">
            <label for="city">Місто</label>
            <input id="city" type="text" name="city" />
          </div>

          <div class="admin-field">
            <label for="place">Локація</label>
            <input id="place" type="text" name="place" />
          </div>

          <div class="admin-field">
            <label for="date">Дата</label>
            <input id="date" type="date" name="date" required />
          </div>

          <div class="admin-field">
            <label for="time">Час</label>
            <input id="time" type="text" name="time" placeholder="Наприклад 19:00" />
          </div>

          <div class="admin-field">
            <label for="description">Опис</label>
            <textarea id="description" name="description" rows="5"></textarea>
          </div>

          <div class="admin-field">
            <label for="ticket_link">Посилання на квитки</label>
            <input id="ticket_link" type="text" name="ticket_link" placeholder="https://..." />
          </div>

          <div class="admin-actions">
            <button class="btn btn-primary" type="submit">Зберегти</button>
            <a class="btn btn-secondary" href="/admin/events">Скасувати</a>
          </div>
        </form>
      </main>
    </div>
  </div>
</body>
</html>